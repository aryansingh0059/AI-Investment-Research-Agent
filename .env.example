# Environment Variables

# ─── AI Models ────────────────────────────────────────────────────────────────
# Primary LLM: Google Gemini 2.5 Flash (retries 3x on 503 before Groq fallback)
# Get API key at https://aistudio.google.com/app/apikey (Free tier available)
GEMINI_API_KEY=

# Fallback LLM: Groq (llama-3.3-70b-versatile) — used when Gemini fails/unavailable
# Get API key at https://console.groq.com (Free tier available)
GROQ_API_KEY=

# ─── Financial Data ───────────────────────────────────────────────────────────
# Yahoo Finance: No API key required — data fetched via yahoo-finance2 npm package

# Finnhub (used ONLY for: competitor peer symbols + company logo)
# Free tier available at https://finnhub.io
FINNHUB_API_KEY=

# ─── News & Web ───────────────────────────────────────────────────────────────
# NewsAPI (Latest company news — top 5 articles)
# Free tier available at https://newsapi.org
NEWS_API_KEY=

# Tavily (AI-powered web search — top 3 results)
# Free tier available at https://tavily.com
TAVILY_API_KEY=

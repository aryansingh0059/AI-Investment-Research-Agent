# Environment Variables

# ─── AI Models ──────────────────────────────────────────────────────────────
# Primary LLM: Google Gemini 1.5 Flash
# Get API key at https://aistudio.google.com/app/apikey (Free tier available)
GEMINI_API_KEY=

# Fallback LLM: Groq (llama-3.3-70b-versatile) — used when Gemini fails/unavailable
# Get API key at https://console.groq.com (Free tier available)
GROQ_API_KEY=

# ─── Financial Data ──────────────────────────────────────────────────────────
# Finnhub (Company profiles, stock data, financial metrics, peers)
# Free tier available at https://finnhub.io
FINNHUB_API_KEY=

# Financial Modeling Prep (Income statements, balance sheets, cash flow)
# Free tier available at https://financialmodelingprep.com
FMP_API_KEY=

# ─── News & Web ──────────────────────────────────────────────────────────────
# NewsAPI (Latest company news)
# Free tier available at https://newsapi.org
NEWS_API_KEY=

# Tavily (AI-powered web search)
# Free tier available at https://tavily.com
TAVILY_API_KEY=


